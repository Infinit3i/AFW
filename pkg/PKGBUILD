# Maintainer: infinit3i
pkgname=afw
pkgver=0.1.0
pkgrel=1
pkgdesc="Application Firewall - eBPF process monitoring with dynamic nftables rules"
arch=('x86_64')
url="https://github.com/infinit3i/AFW"
license=('GPL-3.0-or-later')
depends=('nftables')
makedepends=('rust' 'clang' 'llvm' 'bpf-linker')
backup=('etc/afw/afw.toml')
source=()
sha256sums=()

build() {
    cd "$startdir/.."

    # Build eBPF programs
    cargo xtask build-ebpf --release

    # Build userspace binary
    cargo build --release -p afw
}

package() {
    cd "$startdir/.."

    # Install binary
    install -Dm755 "target/release/afw" "$pkgdir/usr/bin/afw"

    # Install config
    install -Dm644 "config/afw.toml" "$pkgdir/etc/afw/afw.toml"

    # Install systemd service
    install -Dm644 "systemd/afw.service" "$pkgdir/usr/lib/systemd/system/afw.service"
}
